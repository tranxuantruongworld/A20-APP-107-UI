{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "python3 scripts/log_hook.py",
        "powershell": "$py = if (Test-Path .venv\\Scripts\\python.exe) { '.venv\\Scripts\\python.exe' } else { 'python' }; & $py scripts/log_hook.py",
        "env": { "AI_TOOL_NAME": "copilot" },
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python3 scripts/log_hook.py",
        "powershell": "$py = if (Test-Path .venv\\Scripts\\python.exe) { '.venv\\Scripts\\python.exe' } else { 'python' }; & $py scripts/log_hook.py",
        "env": { "AI_TOOL_NAME": "copilot" },
        "timeoutSec": 10
      }
    ]
  }
}
